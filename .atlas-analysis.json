  "keyFeatures": [
    "Convention-based object-to-object mapping with zero configuration",
    "4x faster than AutoMapper with 1/3 the memory usage",
    "Queryable projections via ProjectToType<T>()",
    "Code generation for DTOs, extension methods, and mapper classes",
    "Dependency injection support with IMapper interface",
    "Configurable settings: custom mapping, ignoring members, constructor mapping, naming conventions",
    "Support for records, collections, dictionaries, enums, and primitives",
    "Before/after mapping hooks and runtime parameter passing",
    "Step-into debugging with ExpressionDebugger",
    "Assembly scanning via IRegister for organized configuration"
  ],
  "publicApiSurface": [
