    "void Adapt<TSource, TDestination>(this TSource source, TDestination destination)",
    "IQueryable<TDestination> ProjectToType<TDestination>(this IQueryable source)",
    "TypeAdapterConfig.GlobalSettings",
    "TypeAdapterConfig<TSource, TDestination>.NewConfig()",
    "TypeAdapterConfig<TSource, TDestination>.ForType()",
    "TypeAdapterConfig.GlobalSettings.Scan(params Assembly[] assemblies)",
